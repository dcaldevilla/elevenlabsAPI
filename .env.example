# Shopify
SHOPIFY_SHOP=tu-tienda.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-07

# Clave para proteger los endpoints (la que ElevenLabs enviará en X-API-Key)
MW_API_KEY=cambia-esto-por-una-clave-segura

# Location ID de Vitoria en Shopify (gid://shopify/Location/XXXXXXXXX)
SHOPIFY_VITORIA_LOCATION_ID=gid://shopify/Location/XXXXXXXXX

# Puerto (opcional, por defecto 3000)
PORT=3000
